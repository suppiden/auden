---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="packages"
  class="relative py-28 md:py-36 px-6 md:px-10 bg-charcoal overflow-hidden"
  aria-labelledby="identity-headline"
>
  <!-- Floating gradient orbs — pre-blurred via radial-gradient (no blur filter) -->
  <div
    class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(255,77,0,0.12) 0%, transparent 50%); will-change: transform;"
    aria-hidden="true"
    data-parallax-orb
    data-speed="0.04"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(123,63,160,0.12) 0%, transparent 50%); will-change: transform;"
    aria-hidden="true"
    data-parallax-orb
    data-speed="-0.03"
  ></div>

  <div class="max-w-8xl mx-auto relative" style="z-index: 10;">

    <!-- ① Auden Sonic Identity ─────────────────────────────────── -->
    <div class="mb-24 md:mb-32">
      <!-- Ghost "02" -->
      <div class="relative">
        <span
          class="absolute -right-4 md:right-0 -top-6 font-black leading-none tracking-tighter select-none pointer-events-none"
          style="font-size: clamp(6rem, 18vw, 16rem); color: rgb(var(--color-cream)); opacity: 0.04;"
          aria-hidden="true"
        >02</span>

        <div class="relative" data-reveal>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-mid mb-5">
            {t.identity.eyebrow}
          </p>
          <h2
            id="identity-headline"
            class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] text-cream mb-10 tracking-tight uppercase"
            data-split-reveal
          >
            {t.identity.headline}
          </h2>
        </div>
      </div>

      <!-- Glassmorphism product card -->
      <div
        class="rounded-2xl border border-cream/10 p-8 md:p-12 backdrop-blur-xl"
        style="background: rgba(255,255,255,0.04);"
        data-reveal
      >
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
          <div>
            <p class="text-base md:text-lg text-cream/75 leading-relaxed mb-8">
              {t.identity.description}
            </p>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 px-7 py-3.5 bg-cream text-charcoal text-sm font-medium tracking-wide hover:bg-accent hover:text-cream transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream relative overflow-hidden group"
            >
              <span class="relative z-10">{t.identity.cta}</span>
              <span
                class="absolute inset-0 bg-fire scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"
                aria-hidden="true"
              ></span>
            </a>
          </div>
          <ul class="flex flex-col gap-3.5">
            {t.identity.includes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-cream/65">
                <span
                  class="mt-[6px] w-1 h-1 rounded-full flex-shrink-0"
                  style="background: rgb(var(--color-fire));"
                  aria-hidden="true"
                />
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- ② Auden Sonic Method ──────────────────────────────────── -->
    <div>
      <div class="mb-12" data-reveal>
        <p class="text-xs font-medium tracking-[0.2em] uppercase text-mid mb-5">
          {t.identity.methodEyebrow}
        </p>
        <h3
          class="text-3xl md:text-4xl font-black leading-tight text-cream tracking-tight uppercase"
          data-split-reveal
        >
          {t.identity.methodHeadline}
        </h3>
      </div>

      <div class="grid md:grid-cols-2 gap-px bg-cream/8" data-reveal-stagger>
        {t.identity.phases.map((phase) => (
          <div
            class="bg-charcoal p-8 md:p-10 group hover:bg-cream/5 transition-colors duration-300"
            data-tilt
          >
            <span
              class="text-[10px] font-medium tracking-[0.25em] block mb-6 transition-colors duration-300 group-hover:text-fire"
              style="color: rgb(var(--color-mid));"
            >{phase.number}</span>
            <h4 class="text-xl font-black text-cream mb-3 tracking-tight">{phase.name}</h4>
            <p class="text-sm text-mid leading-relaxed">{phase.description}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- ── Logo Reveal: sonic pulse section — always dark for impact ── -->
<div class="relative py-36 md:py-52 overflow-hidden" style="background: #000;" aria-hidden="true">
  <!-- Sonar ripples emanating from logo -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="sonar-ring sonar-ring--1"></div>
    <div class="sonar-ring sonar-ring--2"></div>
    <div class="sonar-ring sonar-ring--3"></div>
  </div>

  <!-- Waveform canvas over logo -->
  <canvas
    id="logo-wave-canvas"
    class="absolute inset-0 w-full h-full pointer-events-none"
    style="z-index: 3;"
    aria-hidden="true"
  ></canvas>

  <!-- Logo — rendered as CSS text to avoid PNG background issues -->
  <div class="relative flex items-center justify-center" style="z-index: 2;" data-logo-reveal>
    <!-- _black.png = white text on black bg → black bg merges with #000 section -->
    <img
      src="/auden_u_palabra_black.png"
      alt=""
      class="logo-pulse"
      style="width: clamp(18rem, 55vw, 50rem); opacity: 0.25;"
    />
  </div>
</div>

<script>
  // ── Parallax orbs — scroll-driven (not rAF) ──────────────────────
  const parallaxOrbs = document.querySelectorAll<HTMLElement>('[data-parallax-orb]');
  if (parallaxOrbs.length > 0) {
    function updateOrbs() {
      parallaxOrbs.forEach(orb => {
        const speed = parseFloat(orb.dataset.speed || '0.03');
        const section = orb.closest('section');
        if (!section) return;
        const rect = section.getBoundingClientRect();
        orb.style.transform = `translateY(${-rect.top * speed * 10}px)`;
      });
    }
    window.addEventListener('scroll', updateOrbs, { passive: true });
    updateOrbs();
  }

  // ── Logo reveal — scroll-driven (not rAF) ─────────────────────────
  const logoReveal = document.querySelector<HTMLElement>('[data-logo-reveal]');
  if (logoReveal) {
    function updateLogoReveal() {
      const rect = logoReveal!.parentElement!.getBoundingClientRect();
      const viewH = window.innerHeight;
      if (rect.bottom < -100 || rect.top > viewH + 100) return;
      const p = Math.max(0, Math.min(1, (viewH - rect.top) / (viewH * 0.8)));
      logoReveal!.style.transform = `scale(${0.7 + p * 0.3})`;
      logoReveal!.style.opacity = `${p}`;
    }
    window.addEventListener('scroll', updateLogoReveal, { passive: true });
    updateLogoReveal();
  }

  // ── Logo waveform canvas — visibility-gated ────────────────────────
  const logoWaveCanvas = document.getElementById('logo-wave-canvas') as HTMLCanvasElement | null;
  if (logoWaveCanvas) {
    const ctx = logoWaveCanvas.getContext('2d')!;
    let w = 0, h = 0;
    let logoWaveVisible = false;

    function resizeLogoWave() {
      const rect = logoWaveCanvas!.parentElement!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio, 2);
      w = rect.width;
      h = rect.height;
      logoWaveCanvas!.width = w * dpr;
      logoWaveCanvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resizeLogoWave();
    window.addEventListener('resize', resizeLogoWave);

    let phase = 0;
    const waveConfigs = [
      { amp: 45, freq: 0.007, color: '255, 77, 0', alpha: 0.35, lineW: 4, offset: 0 },
      { amp: 32, freq: 0.013, color: '123, 63, 160', alpha: 0.28, lineW: 3, offset: 1.5 },
      { amp: 55, freq: 0.004, color: '255, 100, 30', alpha: 0.20, lineW: 6, offset: 3 },
      { amp: 22, freq: 0.019, color: '200, 60, 120', alpha: 0.18, lineW: 2, offset: 4.5 },
    ];

    function drawLogoWave() {
      if (!logoWaveVisible) return;
      ctx.clearRect(0, 0, w, h);
      phase += 0.008;
      const cy = h * 0.5;

      waveConfigs.forEach(wc => {
        ctx.beginPath();
        ctx.moveTo(0, cy);
        for (let x = 0; x <= w; x += 4) {
          const env = Math.sin(Math.PI * x / w);
          const y = cy + Math.sin(x * wc.freq + phase + wc.offset) * wc.amp * env;
          ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(${wc.color}, ${wc.alpha})`;
        ctx.lineWidth = wc.lineW;
        ctx.stroke();
      });

      requestAnimationFrame(drawLogoWave);
    }

    const logoSection = logoWaveCanvas.closest('[aria-hidden]') || logoWaveCanvas.parentElement!;
    new IntersectionObserver(([e]) => {
      logoWaveVisible = e.isIntersecting;
      if (logoWaveVisible) requestAnimationFrame(drawLogoWave);
    }, { threshold: 0 }).observe(logoSection);
  }
</script>
