---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="packages"
  class="relative py-28 md:py-36 px-6 md:px-10 bg-charcoal overflow-hidden"
  aria-labelledby="identity-headline"
>
  <!-- Floating gradient orbs (parallax on scroll) -->
  <div
    class="absolute top-0 right-0 w-[520px] h-[520px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, #FF4D00 0%, transparent 65%); opacity: 0.12; filter: blur(90px);"
    aria-hidden="true"
    data-parallax-orb
    data-speed="0.04"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[420px] h-[420px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, #7B3FA0 0%, transparent 65%); opacity: 0.12; filter: blur(90px);"
    aria-hidden="true"
    data-parallax-orb
    data-speed="-0.03"
  ></div>

  <!-- Frequency bars canvas background -->
  <canvas
    id="freq-bars-canvas"
    class="absolute inset-0 w-full h-full pointer-events-none"
    style="opacity: 0.09; z-index: 1;"
    aria-hidden="true"
  ></canvas>

  <div class="max-w-8xl mx-auto relative" style="z-index: 10;">

    <!-- ① Auden Sonic Identity ─────────────────────────────────── -->
    <div class="mb-24 md:mb-32">
      <!-- Ghost "02" -->
      <div class="relative">
        <span
          class="absolute -right-4 md:right-0 -top-6 font-black leading-none tracking-tighter select-none pointer-events-none"
          style="font-size: clamp(6rem, 18vw, 16rem); color: rgb(var(--color-cream)); opacity: 0.04;"
          aria-hidden="true"
        >02</span>

        <div class="relative" data-reveal>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-mid mb-5">
            {t.identity.eyebrow}
          </p>
          <h2
            id="identity-headline"
            class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] text-cream mb-10 tracking-tight"
            data-reveal-text
          >
            {t.identity.headline}
          </h2>
        </div>
      </div>

      <!-- Glassmorphism product card -->
      <div
        class="rounded-2xl border border-cream/10 p-8 md:p-12 backdrop-blur-xl"
        style="background: rgba(255,255,255,0.04);"
        data-reveal
      >
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
          <div>
            <p class="text-base md:text-lg text-cream/75 leading-relaxed mb-8">
              {t.identity.description}
            </p>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 px-7 py-3.5 bg-cream text-charcoal text-sm font-medium tracking-wide hover:bg-accent hover:text-cream transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream relative overflow-hidden group"
            >
              <span class="relative z-10">{t.identity.cta}</span>
              <span
                class="absolute inset-0 bg-fire scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"
                aria-hidden="true"
              ></span>
            </a>
          </div>
          <ul class="flex flex-col gap-3.5">
            {t.identity.includes.map((item) => (
              <li class="flex items-start gap-3 text-sm text-cream/65">
                <span
                  class="mt-[6px] w-1 h-1 rounded-full flex-shrink-0"
                  style="background: rgb(var(--color-fire));"
                  aria-hidden="true"
                />
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- ② Auden Sonic Method ──────────────────────────────────── -->
    <div class="mb-24 md:mb-32">
      <div class="mb-12" data-reveal>
        <p class="text-xs font-medium tracking-[0.2em] uppercase text-mid mb-5">
          {t.identity.methodEyebrow}
        </p>
        <h3
          class="text-3xl md:text-4xl font-black leading-tight text-cream tracking-tight"
          data-reveal-text
        >
          {t.identity.methodHeadline}
        </h3>
      </div>

      <div class="grid md:grid-cols-2 gap-px bg-cream/8" data-reveal-stagger>
        {t.identity.phases.map((phase) => (
          <div
            class="bg-charcoal p-8 md:p-10 group hover:bg-cream/5 transition-colors duration-300"
            data-tilt
          >
            <span
              class="text-[10px] font-medium tracking-[0.25em] block mb-6 transition-colors duration-300 group-hover:text-fire"
              style="color: rgb(var(--color-mid));"
            >{phase.number}</span>
            <h4 class="text-xl font-black text-cream mb-3 tracking-tight">{phase.name}</h4>
            <p class="text-sm text-mid leading-relaxed">{phase.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ③ Individual services ─────────────────────────────────── -->
    <div>
      <div class="mb-10" data-reveal>
        <p class="text-xs font-medium tracking-[0.2em] uppercase text-mid mb-5">
          {t.identity.servicesEyebrow}
        </p>
        <h3
          class="text-3xl md:text-4xl font-black leading-tight text-cream tracking-tight"
          data-reveal-text
        >
          {t.identity.servicesHeadline}
        </h3>
      </div>

      <ol class="border-t border-cream/10">
        {t.identity.services.map((service, i) => (
          <li
            class="border-b border-cream/10 py-6 md:py-7 flex items-center gap-8 group hover:bg-cream/5 transition-colors duration-300 px-2 cursor-default"
            data-reveal-wipe
            style={`transition-delay: ${i * 0.06}s`}
          >
            <span class="text-[10px] tracking-[0.2em] text-mid w-6 shrink-0 group-hover:text-fire transition-colors duration-300">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-base text-cream/75 font-medium flex-1">{service.name}</span>
            <span class="text-mid opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm" aria-hidden="true">&rarr;</span>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>

<script>
  // ── Frequency bars canvas animation ──────────────────────────────
  const freqCanvas = document.getElementById('freq-bars-canvas') as HTMLCanvasElement | null;
  if (freqCanvas) {
    const ctx = freqCanvas.getContext('2d')!;
    let w = 0, h = 0;
    const BAR_COUNT = 80;
    const bars: number[] = Array.from({ length: BAR_COUNT }, () => Math.random() * 0.3);
    const targets: number[] = Array.from({ length: BAR_COUNT }, () => Math.random());

    function resizeFreq() {
      const rect = freqCanvas!.parentElement!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio, 2);
      w = rect.width;
      h = rect.height;
      freqCanvas!.width = w * dpr;
      freqCanvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resizeFreq();
    window.addEventListener('resize', resizeFreq);

    function drawBars() {
      ctx.clearRect(0, 0, w, h);

      const barW = w / BAR_COUNT;
      const maxH = h * 0.65;

      for (let i = 0; i < BAR_COUNT; i++) {
        // Smooth interpolation toward target
        bars[i] += (targets[i] - bars[i]) * 0.03;

        // Randomly update targets for organic movement
        if (Math.random() < 0.025) {
          targets[i] = Math.random();
        }

        const barH = bars[i] * maxH;
        const x = i * barW;
        const y = h - barH;

        // Gradient from fire orange to purple across the bars
        const t = i / BAR_COUNT;
        const r = Math.round(255 - t * 132);
        const g = Math.round(77 - t * 14);
        const b = Math.round(t * 160);

        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.55)`;
        ctx.fillRect(x + 1, y, barW - 2, barH);
      }

      requestAnimationFrame(drawBars);
    }
    requestAnimationFrame(drawBars);
  }

  // ── Parallax orbs on scroll ────────────────────────────────────
  const parallaxOrbs = document.querySelectorAll<HTMLElement>('[data-parallax-orb]');
  if (parallaxOrbs.length > 0) {
    function updateOrbs() {
      const scrollY = window.scrollY;
      parallaxOrbs.forEach(orb => {
        const speed = parseFloat(orb.dataset.speed || '0.03');
        const section = orb.closest('section');
        if (!section) return;
        const rect = section.getBoundingClientRect();
        const sectionScroll = -rect.top;
        orb.style.transform = `translateY(${sectionScroll * speed * 10}px)`;
      });
      requestAnimationFrame(updateOrbs);
    }
    requestAnimationFrame(updateOrbs);
  }
</script>
