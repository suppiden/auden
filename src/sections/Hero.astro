---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

// Waveform bars: height percentages for visual variation
const bars = [30, 55, 80, 45, 95, 60, 35, 75, 50, 90, 40, 65, 85, 50, 70, 38, 92, 58, 43, 78, 62, 35, 88, 48, 72];
---

<section
  id="home"
  class="relative flex flex-col items-center justify-center min-h-screen px-6 md:px-10 pt-16 overflow-hidden bg-cream"
  aria-labelledby="hero-headline"
>
  <!-- Waveform visual -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 flex items-end justify-center gap-[3px] px-8 opacity-20 pointer-events-none"
    aria-hidden="true"
  >
    {bars.map((h, i) => (
      <div
        class="wave-bar flex-1 max-w-[6px] bg-charcoal rounded-t-sm"
        style={`height: ${h}%; --duration: ${0.9 + (i % 7) * 0.15}s; --delay: ${(i * 0.06).toFixed(2)}s;`}
      />
    ))}
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-3xl text-center">
    <p class="section-eyebrow mb-6">{t.hero.eyebrow}</p>

    <h1
      id="hero-headline"
      class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-serif leading-none tracking-tight text-charcoal mb-8"
    >
      {t.hero.headline}
    </h1>

    <p class="text-base md:text-lg text-mid max-w-xl mx-auto leading-relaxed mb-12">
      {t.hero.subheadline}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href={t.hero.ctaHref} class="btn-primary">
        {t.hero.cta}
      </a>
      <a href={t.hero.secondaryHref} class="btn-ghost">
        {t.hero.secondary}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40" aria-hidden="true">
    <span class="text-[10px] tracking-[0.25em] uppercase text-mid">Scroll</span>
    <div class="w-px h-8 bg-mid animate-pulse"></div>
  </div>
</section>
