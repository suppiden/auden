---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col items-center justify-center min-h-screen px-6 md:px-10 pt-16 pb-12 overflow-hidden bg-cream"
  aria-labelledby="hero-headline"
>
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover hero-video"
    autoplay muted loop playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src="/new_background/new_background.mp4" type="video/mp4" />
  </video>

  <!-- Overlay — adapts to theme via CSS -->
  <div class="absolute inset-0 hero-overlay" style="z-index: 3;" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative text-center" style="z-index: 10; max-width: 72rem;">
    <h1 id="hero-headline" class="relative mb-3 md:mb-4">
      <span
        id="hero-logo-glow"
        class="absolute inset-0 -inset-x-20 -inset-y-10 pointer-events-none"
        style="opacity: 0; transition: opacity 1.2s ease;"
        aria-hidden="true"
      ></span>
      <!-- Light mode: black logo. Dark mode: white logo (swapped via JS) -->
      <img
        id="hero-wordmark"
        src="/auden_logo_black.png"
        data-src-light="/auden_logo_black.png"
        data-src-dark="/auden_logo_white.png"
        alt="AUDEN"
        class="relative hero-logo"
        style="width: clamp(16rem, 50vw, 40rem); display: inline-block; transition: filter 1.2s ease;"
      />
    </h1>

    <div>
      <p class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black tracking-tight text-charcoal mb-2 uppercase">
        {t.hero.headline}
      </p>

      <p
        class="text-sm sm:text-base md:text-lg font-medium tracking-[0.1em] uppercase text-charcoal/60 mb-10"
        data-reveal
      >
        {t.hero.tagline}
      </p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-5" data-reveal>
      <a
        href={t.hero.ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="hero-cta-btn"
      >
        {t.hero.cta}
      </a>
      <a href={t.hero.secondaryHref} class="hero-cta-btn hero-cta-ghost">
        {t.hero.secondary}
      </a>
    </div>
  </div>

  <!-- Subtle scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" style="z-index: 10;" aria-hidden="true" data-reveal>
    <div class="w-px h-8 overflow-hidden opacity-30">
      <div class="w-full h-full bg-charcoal" style="animation: scroll-line 2s ease-in-out infinite;"></div>
    </div>
  </div>

  <!-- Subtle bottom border -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-border" style="z-index: 10;" aria-hidden="true"></div>
</section>

<style>
  /* ── Light mode ── */
  .hero-video {
    opacity: 0.6;
    filter: brightness(1.15) saturate(0) sepia(0.15);
    will-change: transform;
    transform: translateZ(0);
  }
  .hero-overlay {
    background: linear-gradient(to bottom,
      rgba(245,244,240,0.35) 0%,
      rgba(245,244,240,0.5) 25%,
      rgba(245,244,240,0.88) 48%,
      rgba(245,244,240,0.96) 65%,
      rgba(245,244,240,0.98) 100%
    );
  }
  /* Logo starts white (from intro splash), then transitions to black via class (light mode only) */
  .hero-logo { transition: filter 1.2s ease; }
  :global(.hero-logo-ready) { filter: brightness(0) !important; }
  #hero-logo-glow { background: radial-gradient(ellipse, rgba(245,244,240,0.6) 0%, transparent 70%); }

  /* ── Dark mode — uses white logo image, no filter needed ── */
  :global(.dark) .hero-video {
    opacity: 0.4;
    filter: brightness(0.4) saturate(0);
  }
  :global(.dark) .hero-overlay {
    background: linear-gradient(to bottom,
      rgba(17,17,17,0.3) 0%,
      rgba(17,17,17,0.5) 25%,
      rgba(17,17,17,0.85) 48%,
      rgba(17,17,17,0.95) 65%,
      rgba(17,17,17,0.98) 100%
    );
  }
  :global(.dark) .hero-logo,
  :global(.dark) :global(.hero-logo-ready) { filter: none !important; }
  :global(.dark) #hero-logo-glow { background: radial-gradient(ellipse, rgba(255,77,0,0.15) 0%, transparent 70%); }

  /* ── Hero CTA buttons — semi-transparent, slightly rounded ── */
  /* Light mode: dark text on subtle backgrounds */
  .hero-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 4px;
    color: #1a1a1a;
    border: 1px solid rgb(255 77 0);
    background: rgb(255 77 0 / 0.12);
    backdrop-filter: blur(8px);
    transition: background 0.3s, box-shadow 0.3s, transform 0.2s, color 0.3s;
  }
  .hero-cta-btn:hover {
    background: rgb(255 77 0 / 0.25);
    box-shadow: 0 0 20px rgb(255 77 0 / 0.15);
    transform: translateY(-1px);
  }
  .hero-cta-ghost {
    border-color: rgb(26 26 26 / 0.4);
    background: rgb(26 26 26 / 0.06);
    color: rgb(26 26 26 / 0.8);
  }
  .hero-cta-ghost:hover {
    border-color: rgb(26 26 26 / 0.7);
    background: rgb(26 26 26 / 0.12);
    color: #1a1a1a;
    box-shadow: none;
  }
  /* Dark mode: white text on glowing backgrounds */
  :global(.dark) .hero-cta-btn {
    color: #fff;
    background: rgb(255 77 0 / 0.15);
  }
  :global(.dark) .hero-cta-btn:hover {
    background: rgb(255 77 0 / 0.35);
    box-shadow: 0 0 20px rgb(255 77 0 / 0.2);
  }
  :global(.dark) .hero-cta-ghost {
    border-color: rgb(255 255 255 / 0.2);
    background: rgb(255 255 255 / 0.05);
    color: rgb(255 255 255 / 0.7);
  }
  :global(.dark) .hero-cta-ghost:hover {
    border-color: rgb(255 255 255 / 0.5);
    background: rgb(255 255 255 / 0.1);
    color: #fff;
  }
</style>
