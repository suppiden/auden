---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col items-center justify-center md:justify-start min-h-screen px-6 md:px-10 pt-16 md:pt-[15vh] overflow-hidden"
  aria-labelledby="hero-headline"
>
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    style="opacity: 0.75; filter: grayscale(1) brightness(0.7); will-change: transform; transform: translateZ(0);"
    autoplay muted loop playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src="/animacion_hd.mp4" type="video/mp4" />
  </video>

  <!-- Gradient orbs — pre-blurred radial gradients (no blur filter) -->
  <div
    class="absolute -bottom-32 -left-32 w-[800px] h-[800px] rounded-full pointer-events-none orb-drift"
    style="background: radial-gradient(circle, rgba(255,77,0,0.35) 0%, rgba(255,77,0,0) 55%); z-index: 3; will-change: transform;"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -top-32 -right-32 w-[700px] h-[700px] rounded-full pointer-events-none orb-drift-2"
    style="background: radial-gradient(circle, rgba(123,63,160,0.28) 0%, rgba(123,63,160,0) 55%); z-index: 3; will-change: transform;"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-charcoal/50" style="z-index: 3;" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative text-center" style="z-index: 10; max-width: 72rem;">
    <h1 id="hero-headline" class="relative mb-4 inline-block">
      <span
        id="hero-logo-glow"
        class="absolute inset-0 -inset-x-20 -inset-y-10 pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(245,244,240,0.25) 0%, transparent 70%); opacity: 0; transition: opacity 1.2s ease;"
        aria-hidden="true"
      ></span>
      <span class="relative inline-block" style="width: clamp(16rem, 50vw, 40rem);">
        <!-- Black logo (revealed underneath) -->
        <img src="/auden_logo_black.png" alt="AUDEN" class="w-full block" />
        <!-- White logo (clipped away left→right to reveal black) -->
        <img
          id="hero-wordmark"
          src="/auden_logo_white.png"
          alt=""
          class="absolute inset-0 w-full block"
          style="transition: clip-path 1.5s cubic-bezier(0.16, 1, 0.3, 1);"
          aria-hidden="true"
        />
      </span>
    </h1>

    <p
      class="text-xl sm:text-2xl md:text-3xl font-light tracking-wide text-cream/70 mb-6 uppercase"
      style="letter-spacing: 0.15em;"
      data-reveal
    >
      {t.hero.headline}
    </p>

    <p class="text-sm md:text-base text-cream/50 max-w-md mx-auto leading-relaxed mb-12" data-reveal>
      {t.hero.subheadline}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4" data-reveal>
      <a
        href={t.hero.ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="hero-btn-primary"
      >
        {t.hero.cta}
      </a>
      <a
        href={t.hero.secondaryHref}
        class="hero-btn-ghost"
      >
        {t.hero.secondary}
      </a>
      <a
        href={t.hero.aboutHref}
        class="hero-btn-ghost"
      >
        {t.hero.about}
      </a>
    </div>
  </div>

  <!-- Color-shifting gradient line at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="z-index: 10; background: linear-gradient(90deg, transparent, rgb(var(--color-fire)), #7B3FA0, rgb(var(--color-fire)), transparent); animation: gradient-shift 4s linear infinite; background-size: 200% 100%;" aria-hidden="true"></div>
</section>

