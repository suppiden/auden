---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col items-center justify-center min-h-screen px-6 md:px-10 pt-16 overflow-hidden"
  aria-labelledby="hero-headline"
>
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover opacity-60"
    autoplay
    muted
    loop
    playsinline
    poster="/banner.jpeg"
    aria-hidden="true"
  >
    <source src="/animacion.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay for text legibility -->
  <div class="absolute inset-0 bg-charcoal/50" aria-hidden="true"></div>

  <!-- Content — always on dark video, force cream text -->
  <div class="relative z-10 max-w-4xl text-center">
    <p class="text-xs font-medium tracking-[0.2em] uppercase text-cream/60 mb-6" data-reveal>
      {t.hero.eyebrow}
    </p>

    <h1
      id="hero-headline"
      class="text-6xl sm:text-7xl md:text-8xl lg:text-[9rem] font-serif leading-none tracking-tighter text-cream mb-8"
      data-reveal
    >
      {t.hero.headline}
    </h1>

    <p class="text-base md:text-lg text-cream/70 max-w-xl mx-auto leading-relaxed mb-12" data-reveal>
      {t.hero.subheadline}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4" data-reveal>
      <a href={t.hero.ctaHref} class="btn-primary">
        {t.hero.cta}
      </a>
      <a
        href={t.hero.secondaryHref}
        class="inline-flex items-center gap-2 px-7 py-3.5 border border-cream/40 text-cream text-sm font-medium tracking-wide hover:bg-cream/10 transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream"
      >
        {t.hero.secondary}
      </a>
    </div>
  </div>
</section>
