---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col min-h-screen overflow-hidden"
  style="background: #111;"
  aria-labelledby="hero-headline"
>
  <!-- ── Glowing arc + ambient light ──────────────────────────────── -->

  <!-- Main ambient glow (the "sun" behind the arc) -->
  <div
    class="absolute pointer-events-none"
    style="width: 1100px; height: 1100px; top: -20%; right: 5%; background: radial-gradient(circle, rgba(255,77,0,0.35) 0%, rgba(255,77,0,0.15) 25%, rgba(255,77,0,0.04) 50%, transparent 70%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- Secondary warm glow -->
  <div
    class="absolute pointer-events-none"
    style="width: 700px; height: 700px; top: -5%; right: 18%; background: radial-gradient(circle, rgba(255,120,40,0.2) 0%, transparent 55%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- The arc ring -->
  <div class="hero-arc" aria-hidden="true">
    <div class="hero-arc-ring"></div>
  </div>

  <!-- Subtle bottom-left purple accent -->
  <div
    class="absolute pointer-events-none"
    style="width: 500px; height: 500px; bottom: -10%; left: -5%; background: radial-gradient(circle, rgba(123,63,160,0.1) 0%, transparent 55%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- ── Content ──────────────────────────────────────────────────── -->
  <div class="relative flex flex-col justify-between flex-1 px-6 md:px-10 pt-20 md:pt-24 pb-10" style="z-index: 10;">

    <!-- Top-left: tagline -->
    <div>
      <p
        class="text-lg sm:text-xl md:text-2xl font-light tracking-wide uppercase"
        style="color: rgba(245,244,240,0.65); letter-spacing: 0.15em;"
        data-reveal
      >
        {t.hero.headline}
      </p>
    </div>

    <!-- Center: logo wordmark (positioned slightly right to intersect with arc) -->
    <div class="flex items-center justify-center my-auto py-8 md:py-0 md:pr-[5%]">
      <h1 id="hero-headline" class="relative">
        <span
          id="hero-logo-glow"
          class="absolute inset-0 -inset-x-24 -inset-y-12 pointer-events-none"
          style="background: radial-gradient(ellipse, rgba(245,244,240,0.12) 0%, transparent 70%); opacity: 0; transition: opacity 1.2s ease;"
          aria-hidden="true"
        ></span>
        <img
          id="hero-wordmark"
          src="/auden_logo_white.png"
          alt="AUDEN"
          class="relative"
          style="width: clamp(20rem, 55vw, 50rem); display: inline-block; transition: filter 1.2s ease; mix-blend-mode: screen; opacity: 0.85;"
        />
      </h1>
    </div>

    <!-- Bottom-left: description + buttons -->
    <div>
      <p class="text-sm md:text-base leading-relaxed max-w-sm mb-6" style="color: rgba(245,244,240,0.4);" data-reveal>
        {t.hero.subheadline}
      </p>
      <div class="flex flex-wrap gap-3" data-reveal>
        <a
          href={t.hero.ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-btn-primary"
        >
          {t.hero.cta}
        </a>
        <a href={t.hero.secondaryHref} class="hero-btn-ghost">{t.hero.secondary}</a>
        <a href={t.hero.aboutHref} class="hero-btn-ghost">{t.hero.about}</a>
      </div>
    </div>
  </div>

  <!-- Bottom gradient line -->
  <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="z-index: 10; background: linear-gradient(90deg, transparent, rgb(var(--color-fire)), #7B3FA0, rgb(var(--color-fire)), transparent); animation: gradient-shift 4s linear infinite; background-size: 200% 100%;" aria-hidden="true"></div>
</section>

<style>
  /* ── Glowing arc ring ─────────────────────────────────────────── */
  .hero-arc {
    position: absolute;
    /* Positioned so the left crescent of the circle is visible */
    top: -30%;
    right: -10%;
    width: clamp(550px, 70vw, 1000px);
    height: clamp(550px, 70vw, 1000px);
    z-index: 2;
    pointer-events: none;
  }

  .hero-arc-ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 77, 0, 0.5);
    background: radial-gradient(circle at 40% 50%, rgba(255, 77, 0, 0.06) 0%, transparent 60%);
    box-shadow:
      /* Tight inner glow */
      inset 0 0 60px rgba(255, 77, 0, 0.12),
      inset 0 0 120px rgba(255, 77, 0, 0.06),
      /* Main outer glow */
      0 0 40px rgba(255, 77, 0, 0.15),
      0 0 80px rgba(255, 77, 0, 0.1),
      0 0 180px rgba(255, 77, 0, 0.06),
      0 0 350px rgba(255, 77, 0, 0.03);
    animation: arc-breathe 8s ease-in-out infinite;
  }

  @keyframes arc-breathe {
    0%, 100% {
      border-color: rgba(255, 77, 0, 0.5);
      box-shadow:
        inset 0 0 60px rgba(255, 77, 0, 0.12),
        inset 0 0 120px rgba(255, 77, 0, 0.06),
        0 0 40px rgba(255, 77, 0, 0.15),
        0 0 80px rgba(255, 77, 0, 0.1),
        0 0 180px rgba(255, 77, 0, 0.06),
        0 0 350px rgba(255, 77, 0, 0.03);
    }
    50% {
      border-color: rgba(255, 77, 0, 0.7);
      box-shadow:
        inset 0 0 80px rgba(255, 77, 0, 0.18),
        inset 0 0 160px rgba(255, 77, 0, 0.1),
        0 0 60px rgba(255, 77, 0, 0.22),
        0 0 120px rgba(255, 77, 0, 0.15),
        0 0 250px rgba(255, 77, 0, 0.08),
        0 0 450px rgba(255, 77, 0, 0.04);
    }
  }

  /* ── Mobile adjustments ───────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero-arc {
      top: -20%;
      right: -25%;
      width: 450px;
      height: 450px;
    }
  }
</style>
