---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col min-h-screen overflow-hidden"
  style="background: #111;"
  aria-labelledby="hero-headline"
>
  <!-- ── Glowing arc ring ─────────────────────────────────────────── -->
  <div class="hero-arc" aria-hidden="true">
    <div class="hero-arc-ring"></div>
  </div>

  <!-- Ambient glow behind the arc -->
  <div
    class="absolute pointer-events-none"
    style="width: 900px; height: 900px; top: -10%; right: -5%; background: radial-gradient(circle, rgba(255,77,0,0.25) 0%, rgba(255,77,0,0.08) 30%, transparent 60%); z-index: 1;"
    aria-hidden="true"
  ></div>
  <div
    class="absolute pointer-events-none"
    style="width: 600px; height: 600px; top: 5%; right: 15%; background: radial-gradient(circle, rgba(255,77,0,0.15) 0%, transparent 50%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- Subtle purple accent -->
  <div
    class="absolute pointer-events-none"
    style="width: 500px; height: 500px; bottom: -10%; left: -5%; background: radial-gradient(circle, rgba(123,63,160,0.12) 0%, transparent 55%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- ── Content ──────────────────────────────────────────────────── -->
  <div class="relative flex flex-col justify-between flex-1 px-6 md:px-10 pt-20 md:pt-24 pb-10" style="z-index: 10;">

    <!-- Top: tagline -->
    <div>
      <p
        class="text-xl sm:text-2xl md:text-3xl font-light tracking-wide uppercase"
        style="color: rgba(245,244,240,0.7); letter-spacing: 0.15em;"
        data-reveal
      >
        {t.hero.headline}
      </p>
    </div>

    <!-- Center: logo wordmark -->
    <div class="flex items-center justify-center my-auto py-12 md:py-0">
      <h1 id="hero-headline" class="relative">
        <span
          id="hero-logo-glow"
          class="absolute inset-0 -inset-x-20 -inset-y-10 pointer-events-none"
          style="background: radial-gradient(ellipse, rgba(245,244,240,0.15) 0%, transparent 70%); opacity: 0; transition: opacity 1.2s ease;"
          aria-hidden="true"
        ></span>
        <img
          id="hero-wordmark"
          src="/auden_logo_white.png"
          alt="AUDEN"
          class="relative hero-wordmark-gradient"
          style="width: clamp(18rem, 55vw, 48rem); display: inline-block; transition: filter 1.2s ease;"
        />
      </h1>
    </div>

    <!-- Bottom: description + buttons -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <!-- Left: sub + description -->
      <div class="max-w-md">
        <p class="text-sm md:text-base leading-relaxed mb-6" style="color: rgba(245,244,240,0.45);" data-reveal>
          {t.hero.subheadline}
        </p>
        <div class="flex flex-wrap gap-3" data-reveal>
          <a
            href={t.hero.ctaHref}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-btn-primary"
          >
            {t.hero.cta}
          </a>
          <a href={t.hero.secondaryHref} class="hero-btn-ghost">{t.hero.secondary}</a>
          <a href={t.hero.aboutHref} class="hero-btn-ghost">{t.hero.about}</a>
        </div>
      </div>

      <!-- Right: nothing for now, keeps layout balanced -->
    </div>
  </div>

  <!-- Bottom gradient line -->
  <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="z-index: 10; background: linear-gradient(90deg, transparent, rgb(var(--color-fire)), #7B3FA0, rgb(var(--color-fire)), transparent); animation: gradient-shift 4s linear infinite; background-size: 200% 100%;" aria-hidden="true"></div>
</section>

<style>
  /* ── Glowing arc ring ─────────────────────────────────────────── */
  .hero-arc {
    position: absolute;
    top: -25%;
    right: -15%;
    width: clamp(500px, 65vw, 900px);
    height: clamp(500px, 65vw, 900px);
    z-index: 2;
    pointer-events: none;
  }

  .hero-arc-ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid rgba(255, 77, 0, 0.6);
    box-shadow:
      /* Inner glow */
      inset 0 0 80px rgba(255, 77, 0, 0.15),
      inset 0 0 160px rgba(255, 77, 0, 0.08),
      /* Outer glow */
      0 0 60px rgba(255, 77, 0, 0.2),
      0 0 120px rgba(255, 77, 0, 0.12),
      0 0 240px rgba(255, 77, 0, 0.06);
    animation: arc-pulse 6s ease-in-out infinite;
  }

  @keyframes arc-pulse {
    0%, 100% {
      box-shadow:
        inset 0 0 80px rgba(255, 77, 0, 0.15),
        inset 0 0 160px rgba(255, 77, 0, 0.08),
        0 0 60px rgba(255, 77, 0, 0.2),
        0 0 120px rgba(255, 77, 0, 0.12),
        0 0 240px rgba(255, 77, 0, 0.06);
      border-color: rgba(255, 77, 0, 0.6);
    }
    50% {
      box-shadow:
        inset 0 0 100px rgba(255, 77, 0, 0.2),
        inset 0 0 200px rgba(255, 77, 0, 0.12),
        0 0 80px rgba(255, 77, 0, 0.3),
        0 0 160px rgba(255, 77, 0, 0.18),
        0 0 320px rgba(255, 77, 0, 0.08);
      border-color: rgba(255, 77, 0, 0.8);
    }
  }

  /* ── Responsive arc positioning ───────────────────────────────── */
  @media (max-width: 768px) {
    .hero-arc {
      top: -15%;
      right: -30%;
      width: 400px;
      height: 400px;
    }
  }
</style>
