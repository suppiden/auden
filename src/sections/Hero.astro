---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative min-h-screen overflow-hidden"
  style="background: #111;"
  aria-labelledby="hero-headline"
>
  <!-- ── Diagonal repeating text ────────────────────────────────── -->
  <div class="hero-diag" aria-hidden="true">
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
    <p class="hero-diag-line">{t.hero.subheadline} &middot; {t.hero.subheadline} &middot; {t.hero.subheadline}</p>
  </div>

  <!-- ── Ambient glow behind the U ──────────────────────────────── -->
  <div
    class="absolute pointer-events-none"
    style="width: 500px; height: 500px; top: 25%; left: 15%; background: radial-gradient(circle, rgba(255,77,0,0.15) 0%, rgba(255,77,0,0.05) 35%, transparent 60%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- ── Vertical label ─────────────────────────────────────────── -->
  <div class="hero-vertical" data-reveal-wipe aria-hidden="true">
    <span>{t.hero.headline}</span>
  </div>

  <!-- ── Content ────────────────────────────────────────────────── -->
  <div class="relative flex flex-col min-h-screen px-6 md:px-10 pt-20 md:pt-28 pb-8 md:pb-10" style="z-index: 10;">

    <!-- Giant AUDEN text, centered vertically -->
    <div class="flex-1 flex items-center">
      <h1 id="hero-headline" class="hero-title" data-reveal>
        <span id="hero-wordmark" class="hero-title-inner"><span>a</span><span class="hero-u">u</span><span>d</span><span>e</span><span>n</span></span>
      </h1>
    </div>

    <!-- Bottom: coordinates + links + CTA -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="hero-coord" data-reveal>
          01 ———— {t.hero.headline}
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 mt-3" data-reveal>
          <a href={t.hero.secondaryHref} class="hero-link">
            <span class="hero-dot"></span>
            {t.hero.secondary}
          </a>
          <a href={t.hero.aboutHref} class="hero-link">
            <span class="hero-dot"></span>
            {t.hero.about}
          </a>
        </div>
      </div>
      <div data-reveal>
        <a
          href={t.hero.ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-btn-primary"
        >
          {t.hero.cta}
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom gradient line -->
  <div
    class="absolute bottom-0 left-0 right-0 h-[2px]"
    style="z-index: 10; background: linear-gradient(90deg, transparent, rgb(var(--color-fire)), #7B3FA0, rgb(var(--color-fire)), transparent); animation: gradient-shift 4s linear infinite; background-size: 200% 100%;"
    aria-hidden="true"
  ></div>
</section>

<style>
  /* ── Giant title ──────────────────────────────────────────────── */
  .hero-title {
    font-weight: 900;
    font-size: clamp(5.5rem, 17vw, 16rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: #fff;
    text-transform: lowercase;
  }

  .hero-title-inner {
    display: inline-block;
  }

  /* ── Glowing U ────────────────────────────────────────────────── */
  .hero-u {
    color: rgb(255, 77, 0);
    text-shadow:
      0 0 10px rgba(255, 77, 0, 1),
      0 0 30px rgba(255, 77, 0, 0.8),
      0 0 60px rgba(255, 77, 0, 0.5),
      0 0 120px rgba(255, 77, 0, 0.3),
      0 0 200px rgba(255, 77, 0, 0.12);
    animation: u-glow 4s ease-in-out infinite;
  }

  @keyframes u-glow {
    0%, 100% {
      text-shadow:
        0 0 10px rgba(255, 77, 0, 1),
        0 0 30px rgba(255, 77, 0, 0.8),
        0 0 60px rgba(255, 77, 0, 0.5),
        0 0 120px rgba(255, 77, 0, 0.3),
        0 0 200px rgba(255, 77, 0, 0.12);
    }
    50% {
      text-shadow:
        0 0 15px rgba(255, 77, 0, 1),
        0 0 40px rgba(255, 77, 0, 0.85),
        0 0 80px rgba(255, 77, 0, 0.6),
        0 0 150px rgba(255, 77, 0, 0.35),
        0 0 250px rgba(255, 77, 0, 0.18);
    }
  }

  /* ── Coordinate line ──────────────────────────────────────────── */
  .hero-coord {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(255, 77, 0);
  }

  /* ── Text links with fire dots ────────────────────────────────── */
  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.3s;
  }
  .hero-link:hover {
    color: #fff;
  }

  .hero-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgb(255, 77, 0);
    display: inline-block;
    flex-shrink: 0;
  }

  /* ── Vertical label ───────────────────────────────────────────── */
  .hero-vertical {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    background: rgb(245, 244, 240);
    color: rgb(26, 26, 26);
    font-weight: 900;
    font-size: clamp(0.85rem, 1.5vw, 1.35rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2.5rem 0.65rem;
    line-height: 1;
  }

  /* ── Diagonal repeating text ──────────────────────────────────── */
  .hero-diag {
    position: absolute;
    top: 0;
    right: -10%;
    width: 80%;
    height: 100%;
    overflow: hidden;
    z-index: 1;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.2rem;
    transform: rotate(-28deg) translate(15%, -10%);
    -webkit-mask-image: radial-gradient(ellipse 55% 50% at 70% 30%, rgba(0,0,0,0.7) 0%, transparent 60%);
    mask-image: radial-gradient(ellipse 55% 50% at 70% 30%, rgba(0,0,0,0.7) 0%, transparent 60%);
  }

  .hero-diag-line {
    white-space: nowrap;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.04);
    font-weight: 500;
  }

  /* ── Mobile ───────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero-vertical {
      top: auto;
      bottom: 30%;
      right: 0;
      transform: none;
      font-size: 0.7rem;
      padding: 1.5rem 0.5rem;
    }
    .hero-diag {
      display: none;
    }
    .hero-title {
      font-size: clamp(3.8rem, 20vw, 6rem);
    }
  }
</style>
