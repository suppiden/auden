---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="home"
  class="relative flex flex-col items-center justify-center min-h-screen px-6 md:px-10 pt-16 overflow-hidden"
  aria-labelledby="hero-headline"
>
  <!-- Video — grayscale + contrast for duotone base -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    style="opacity: 0.75; filter: grayscale(1) contrast(1.25) brightness(0.75);"
    autoplay muted loop playsinline
    poster="/banner.jpeg"
    aria-hidden="true"
  >
    <source src="/animacion_hd.mp4" type="video/mp4" />
  </video>

  <!-- Duotone: fire orange color wash -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: rgb(var(--color-fire)); opacity: 0.12; mix-blend-mode: color;"
    aria-hidden="true"
  ></div>

  <!-- Scanlines overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.18) 2px, rgba(0,0,0,0.18) 4px); z-index: 2;"
    aria-hidden="true"
  ></div>

  <!-- Gradient orbs -->
  <div
    class="absolute -bottom-32 -left-32 w-[650px] h-[650px] rounded-full pointer-events-none orb-drift"
    style="background: radial-gradient(circle, #FF4D00 0%, transparent 68%); opacity: 0.38; filter: blur(72px); z-index: 3;"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full pointer-events-none orb-drift-2"
    style="background: radial-gradient(circle, #7B3FA0 0%, transparent 68%); opacity: 0.30; filter: blur(72px); z-index: 3;"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-charcoal/50" style="z-index: 3;" aria-hidden="true"></div>

  <!-- U mark watermark — brand presence -->
  <div
    class="absolute bottom-12 right-8 md:right-16 pointer-events-none select-none"
    style="z-index: 4;"
    aria-hidden="true"
  >
    <img
      src="/auden_u_white.png"
      alt=""
      class="w-28 md:w-44 lg:w-60 opacity-[0.07]"
    />
  </div>

  <!-- Content -->
  <div class="relative text-center" style="z-index: 10; max-width: 72rem;">
    <p
      class="text-[10px] font-medium tracking-[0.3em] uppercase mb-8"
      style="color: rgb(var(--color-fire));"
      data-reveal
    >
      {t.hero.eyebrow}
    </p>

    <h1
      id="hero-headline"
      class="text-6xl sm:text-7xl md:text-8xl lg:text-[10rem] font-black leading-none tracking-tighter text-cream mb-8"
      data-scramble
    >
      {t.hero.headline}
    </h1>

    <p class="text-base md:text-lg text-cream/60 max-w-lg mx-auto leading-relaxed mb-14" data-reveal>
      {t.hero.subheadline}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4" data-reveal>
      <a href={t.hero.ctaHref} class="btn-primary">{t.hero.cta}</a>
      <a
        href={t.hero.secondaryHref}
        class="inline-flex items-center gap-2 px-7 py-3.5 border border-cream/25 text-cream text-sm font-medium tracking-wide hover:border-cream/50 hover:bg-cream/8 transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream"
      >
        {t.hero.secondary}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3"
    style="z-index: 10;"
    aria-hidden="true"
  >
    <span class="text-[9px] tracking-[0.3em] uppercase text-cream/25 font-medium">Scroll</span>
    <div class="relative w-px h-10 overflow-hidden" style="background: rgb(255 255 255 / 0.08);">
      <div
        class="absolute inset-x-0 top-0 h-1/2"
        style="background: rgb(var(--color-fire)); animation: scroll-line 1.8s ease-in-out infinite;"
      ></div>
    </div>
  </div>
</section>
