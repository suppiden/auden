---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const items = t.touchpoints.items;
const row1 = items.slice(0, 5);
const row2 = items.slice(5, 10);
---

<section class="py-20 md:py-28 px-6 md:px-10 bg-charcoal" aria-labelledby="touchpoints-headline">
  <div class="max-w-8xl mx-auto">
    <p class="section-eyebrow mb-5" data-reveal>{t.touchpoints.eyebrow}</p>
    <h2
      id="touchpoints-headline"
      class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight text-cream tracking-tight mb-14 md:mb-20"
      data-split-reveal
    >
      {t.touchpoints.headline}
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-y-6 gap-x-4 md:gap-y-8 md:gap-x-6 mb-12 md:mb-16" data-reveal-stagger>
      {[...row1, ...row2].map((item) => (
        <p class="text-sm md:text-base text-cream/80 font-normal">{item}</p>
      ))}
    </div>

    <p class="text-xs md:text-sm text-mid leading-relaxed max-w-2xl" data-reveal>
      {t.touchpoints.footer}
    </p>
  </div>
</section>
