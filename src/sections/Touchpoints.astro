---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const items = t.touchpoints.items;
const row1 = items.slice(0, 5);
const row2 = items.slice(5, 10);
---

<section class="py-20 md:py-28 px-6 md:px-10 bg-charcoal" aria-labelledby="touchpoints-headline">
  <div class="max-w-8xl mx-auto">
    <p class="text-[10px] font-medium tracking-[0.25em] uppercase text-mid mb-5" data-reveal>
      {t.touchpoints.eyebrow}
    </p>
    <h2
      id="touchpoints-headline"
      class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight text-cream tracking-tight mb-16 md:mb-20"
      data-split-reveal
    >
      {t.touchpoints.headline}
    </h2>

    <!-- Row 1 -->
    <div class="flex flex-wrap items-center gap-x-6 md:gap-x-10 gap-y-2 mb-6 md:mb-8" data-reveal>
      {row1.map((item, i) => (
        <span class="text-base md:text-lg text-cream/85 font-normal">
          {item}{i < row1.length - 1 && <span class="ml-6 md:ml-10 text-mid/40">&middot;</span>}
        </span>
      ))}
    </div>

    <!-- Row 2 -->
    <div class="flex flex-wrap items-center gap-x-6 md:gap-x-10 gap-y-2 mb-14 md:mb-16" data-reveal>
      {row2.map((item, i) => (
        <span class="text-base md:text-lg text-cream/85 font-normal">
          {item}{i < row2.length - 1 && <span class="ml-6 md:ml-10 text-mid/40">&middot;</span>}
        </span>
      ))}
    </div>

    <!-- Footer line -->
    <p class="text-xs text-mid/60 leading-relaxed max-w-2xl" data-reveal>
      {t.touchpoints.footer}
    </p>
  </div>
</section>
