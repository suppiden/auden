---
import type { Translations } from '../i18n/en';
import ContactForm from '../components/ContactForm';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const externalUrl = import.meta.env.PUBLIC_EXTERNAL_FORM_URL || 'https://eez6xtvk.forms.app/auden-1';
---

<section id="contact" class="py-28 md:py-36 px-6 md:px-10 bg-cream border-t border-border" aria-labelledby="contact-headline">
  <div class="max-w-8xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">
      <!-- Left: header & info -->
      <div>
        <p class="section-eyebrow mb-5" data-reveal>{t.contact.eyebrow}</p>
        <h2 id="contact-headline" class="section-headline mb-6 uppercase" data-split-reveal>{t.contact.headline}</h2>
        <p class="text-base text-mid leading-relaxed max-w-sm" data-reveal>{t.contact.body}</p>
        <p class="mt-6 text-sm text-mid" data-reveal>
          {t.contact.emailLabel}{' '}
          <a
            href={`mailto:${t.contact.emailAddress}`}
            class="text-charcoal underline underline-offset-4 hover:text-mid transition-colors"
          >{t.contact.emailAddress}</a>
        </p>
      </div>

      <!-- Right: form (React island) -->
      <div>
        <ContactForm
          client:load
          fields={t.contact.fields}
          successMsg={t.contact.success}
          errorMsg={t.contact.error}
          externalCta={t.contact.externalCta}
          externalUrl={externalUrl}
        />
      </div>
    </div>
  </div>
</section>
