---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="extras" class="py-28 md:py-36 px-6 md:px-10 bg-cream" aria-labelledby="extras-headline">
  <div class="max-w-8xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">
      <!-- Left: header -->
      <div>
        <p class="section-eyebrow mb-5">{t.extras.eyebrow}</p>
        <h2 id="extras-headline" class="section-headline">
          {t.extras.headline}
        </h2>
      </div>

      <!-- Right: list -->
      <ul class="divide-y divide-border" aria-label="Available add-ons">
        {t.extras.items.map((item) => (
          <li class="flex items-center justify-between py-5 gap-6">
            <span class="text-sm md:text-base text-charcoal">{item.name}</span>
            <span class="text-sm font-medium text-charcoal whitespace-nowrap">{item.price}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
