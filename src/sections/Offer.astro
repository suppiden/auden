---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="offer" class="py-28 md:py-36 px-6 md:px-10 bg-cream" aria-labelledby="offer-headline">
  <div class="max-w-8xl mx-auto">
    <!-- Header -->
    <div class="max-w-2xl mb-20 md:mb-28">
      <p class="section-eyebrow mb-5">{t.offer.eyebrow}</p>
      <h2 id="offer-headline" class="section-headline mb-8">
        {t.offer.headline}
      </h2>
      <p class="text-base md:text-lg text-mid leading-relaxed max-w-xl">
        {t.offer.body}
      </p>
    </div>

    <!-- Three pillars -->
    <div class="grid md:grid-cols-3 gap-px bg-border border border-border">
      {t.offer.pillars.map((pillar) => (
        <div class="bg-cream p-10 md:p-12">
          <div class="w-8 h-px bg-charcoal mb-8" aria-hidden="true"></div>
          <h3 class="text-xl font-serif text-charcoal mb-4">{pillar.title}</h3>
          <p class="text-sm text-mid leading-relaxed">{pillar.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
