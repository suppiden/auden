---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="offer" class="relative py-20 md:py-28 px-6 md:px-10 bg-cream overflow-hidden" aria-labelledby="offer-headline">
  <!-- 3D SiriWave canvas — layered OVER the text -->
  <canvas
    id="siri-wave-canvas"
    class="absolute inset-0 w-full h-full pointer-events-none"
    style="z-index: 20;"
    aria-hidden="true"
  ></canvas>

  <div class="max-w-8xl mx-auto relative" style="z-index: 1;">
    <!-- MASSIVE headline — always visible so waves flow OVER the letters -->
    <div class="mb-12 md:mb-20">
      <p class="section-eyebrow mb-6" data-reveal>{t.offer.eyebrow}</p>
      <h2
        id="offer-headline"
        class="font-black leading-[0.90] tracking-tighter text-charcoal uppercase"
        style="font-size: clamp(3rem, 10vw, 11rem);"
      >
        {t.offer.headline}
      </h2>
    </div>

    <p class="text-base md:text-lg text-mid leading-relaxed max-w-2xl mb-16 md:mb-24" data-reveal style="position: relative; z-index: 25;">
      {t.offer.body}
    </p>

    <!-- Pillars with 3D flip on scroll -->
    <ol class="border-t border-border">
      {t.offer.pillars.map((pillar, i) => (
        <li
          class="group border-b border-border py-8 md:py-10 flex items-start gap-8 px-2 hover:bg-charcoal/5 transition-colors duration-300 cursor-default overflow-hidden"
          data-pillar
        >
          <span class="text-[10px] tracking-[0.2em] text-mid mt-2 w-6 shrink-0 group-hover:text-fire transition-colors duration-300 font-medium">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="flex-1 overflow-hidden" style="perspective: 900px;">
            <h3
              class="text-2xl md:text-4xl lg:text-5xl font-black text-charcoal tracking-tight"
              style="transform: rotateY(90deg); transform-origin: left center; transition: none;"
              data-pillar-title
            >
              {pillar.title}
            </h3>
            <p
              class="text-sm text-mid mt-3 leading-relaxed max-w-lg opacity-0 translate-y-4"
              data-pillar-body
            >
              {pillar.body}
            </p>
          </div>
          <span class="text-mid opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm mt-2" aria-hidden="true">&rarr;</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- Scroll-velocity text strip -->
<div class="overflow-hidden bg-charcoal py-7 border-y border-cream/10" data-velocity-wrap>
  <div data-scroll-velocity class="whitespace-nowrap will-change-transform">
    <span class="inline-block text-[clamp(3rem,10vw,8rem)] font-black tracking-tighter uppercase select-none velocity-text" aria-hidden="true">
      SOUND&nbsp;&#10038;&nbsp;IDENTITY&nbsp;&#10038;&nbsp;BRAND&nbsp;&#10038;&nbsp;RECOGNITION&nbsp;&#10038;&nbsp;MEMORY&nbsp;&#10038;&nbsp;EMOTION&nbsp;&#10038;&nbsp;SOUND&nbsp;&#10038;&nbsp;IDENTITY&nbsp;&#10038;&nbsp;BRAND&nbsp;&#10038;&nbsp;RECOGNITION&nbsp;&#10038;&nbsp;MEMORY&nbsp;&#10038;&nbsp;EMOTION&nbsp;&#10038;&nbsp;
    </span>
  </div>
</div>

<script>
  // ── 3D SiriWave — flows OVER the text ────────────────────────────
  const siriCanvas = document.getElementById('siri-wave-canvas') as HTMLCanvasElement | null;
  if (siriCanvas) {
    const ctx = siriCanvas.getContext('2d')!;
    let w = 0, h = 0;

    function resizeSiri() {
      const rect = siriCanvas!.parentElement!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio, 2);
      w = rect.width;
      h = rect.height;
      siriCanvas!.width = w * dpr;
      siriCanvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resizeSiri();
    window.addEventListener('resize', resizeSiri);

    // Check dark mode for color adaptation
    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    const waves = [
      { amp: 140, freq: 0.004, speed: 0.009, phase: 0,   lineW: 7, glowW: 28 },
      { amp: 100, freq: 0.007, speed: 0.015, phase: 1.5, lineW: 5, glowW: 20 },
      { amp: 70,  freq: 0.012, speed: 0.019, phase: 3,   lineW: 4, glowW: 14 },
      { amp: 50,  freq: 0.017, speed: 0.013, phase: 4.5, lineW: 3, glowW: 10 },
      { amp: 90,  freq: 0.009, speed: 0.022, phase: 2,   lineW: 4, glowW: 16 },
      { amp: 60,  freq: 0.015, speed: 0.018, phase: 5,   lineW: 3, glowW: 12 },
    ];

    const colors = [
      [255, 77, 0],    // fire
      [123, 63, 160],  // purple
      [255, 100, 30],  // deep orange
      [160, 50, 180],  // violet
      [255, 77, 0],    // fire
      [200, 60, 120],  // magenta accent
    ];

    function drawSiri() {
      ctx.clearRect(0, 0, w, h);

      // Vertical center - offset slightly toward top third
      const cy = h * 0.38;
      const dark = isDark();

      waves.forEach((wave, idx) => {
        wave.phase += wave.speed;
        const [cr, cg, cb] = colors[idx];
        const baseAlpha = dark ? 0.50 : 0.30;

        // Draw glow pass (thick, blurred)
        ctx.beginPath();
        ctx.moveTo(0, cy);
        for (let x = 0; x <= w; x += 3) {
          const env = Math.sin(Math.PI * x / w);
          // Add secondary harmonic for more organic shape
          const y = cy
            + Math.sin(x * wave.freq + wave.phase) * wave.amp * env
            + Math.sin(x * wave.freq * 2.3 + wave.phase * 0.7) * wave.amp * 0.2 * env;
          ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(${cr}, ${cg}, ${cb}, ${baseAlpha * 0.4})`;
        ctx.lineWidth = wave.glowW;
        ctx.lineCap = 'round';
        ctx.stroke();

        // Draw sharp pass (thin, crisp)
        ctx.beginPath();
        ctx.moveTo(0, cy);
        for (let x = 0; x <= w; x += 3) {
          const env = Math.sin(Math.PI * x / w);
          const y = cy
            + Math.sin(x * wave.freq + wave.phase) * wave.amp * env
            + Math.sin(x * wave.freq * 2.3 + wave.phase * 0.7) * wave.amp * 0.2 * env;
          ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(${cr}, ${cg}, ${cb}, ${baseAlpha})`;
        ctx.lineWidth = wave.lineW;
        ctx.lineCap = 'round';
        ctx.stroke();
      });

      requestAnimationFrame(drawSiri);
    }
    requestAnimationFrame(drawSiri);
  }

  // ── 3D pillar rotation on scroll ─────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-pillar]').forEach(li => {
    const title = li.querySelector<HTMLElement>('[data-pillar-title]');
    const body = li.querySelector<HTMLElement>('[data-pillar-body]');
    if (!title) return;

    function updatePillar() {
      const rect = li.getBoundingClientRect();
      const viewH = window.innerHeight;
      const p = Math.max(0, Math.min(1, (viewH - rect.top) / (viewH * 0.6)));

      const rot = 90 - p * 90;
      title!.style.transform = `rotateY(${rot}deg)`;
      title!.style.opacity = `${p}`;

      if (body) {
        const bp = Math.max(0, Math.min(1, (p - 0.4) * 2.5));
        body.style.opacity = `${bp}`;
        body.style.transform = `translateY(${(1 - bp) * 20}px)`;
      }

      requestAnimationFrame(updatePillar);
    }
    requestAnimationFrame(updatePillar);
  });

  // ── Scroll-velocity horizontal text ──────────────────────────────
  const velocityEl = document.querySelector<HTMLElement>('[data-scroll-velocity]');
  if (velocityEl) {
    let lastY = window.scrollY;
    let velocity = 0;
    let posX = 0;

    function tickVelocity() {
      const currentY = window.scrollY;
      const delta = currentY - lastY;
      lastY = currentY;
      velocity += (delta - velocity) * 0.08;
      posX -= velocity * 1.5;
      velocityEl!.style.transform = `translateX(${posX}px)`;
      requestAnimationFrame(tickVelocity);
    }
    requestAnimationFrame(tickVelocity);
  }
</script>
