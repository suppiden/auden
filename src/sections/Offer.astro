---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="offer" class="py-28 md:py-36 px-6 md:px-10 bg-cream" aria-labelledby="offer-headline">
  <div class="max-w-8xl mx-auto">
    <!-- Header -->
    <div class="max-w-2xl mb-20 md:mb-28" data-reveal>
      <p class="section-eyebrow mb-5">{t.offer.eyebrow}</p>
      <h2 id="offer-headline" class="section-headline mb-8">
        {t.offer.headline}
      </h2>
      <p class="text-base md:text-lg text-mid leading-relaxed max-w-xl">
        {t.offer.body}
      </p>
    </div>

    <!-- Numbered services list -->
    <ol class="border-t border-border">
      {t.offer.pillars.map((pillar, i) => (
        <li
          class="group border-b border-border py-8 md:py-10 flex items-start gap-8 px-2 hover:bg-charcoal/5 transition-colors duration-300 cursor-default"
          data-reveal
        >
          <span class="text-[10px] tracking-[0.2em] text-mid mt-1.5 w-6 shrink-0">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="flex-1">
            <h3 class="font-serif text-xl text-charcoal">{pillar.title}</h3>
            <p class="text-sm text-mid mt-2 leading-relaxed overflow-hidden max-h-0 group-hover:max-h-24 transition-all duration-500 ease-in-out">
              {pillar.body}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
