---
import type { Translations } from '../i18n/en';
import { portfolio } from '../data/portfolio';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const hasWork = portfolio.length > 0;
---

<section id="work" class="py-28 md:py-36 px-6 md:px-10 bg-cream border-t border-border" aria-labelledby="work-headline">
  <div class="max-w-8xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 md:mb-24">
      <div>
        <p class="section-eyebrow mb-5" data-reveal>{t.work.eyebrow}</p>
        <h2 id="work-headline" class="section-headline" data-scramble data-reveal-text>{t.work.headline}</h2>
      </div>
    </div>

    {hasWork ? (
      <!-- Portfolio grid — renders when items are available -->
      <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-border border border-border" role="list">
        {portfolio.map((item) => (
          <li class="bg-cream group">
            <a
              href={item.caseStudyUrl ?? '#work'}
              class="block p-8 md:p-10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-charcoal"
              aria-label={`${item.client} — ${item.category}`}
            >
              <!-- Cover image placeholder -->
              {item.cover ? (
                <img
                  src={item.cover}
                  alt={item.client}
                  width="800"
                  height="500"
                  class="w-full aspect-video object-cover mb-8 grayscale group-hover:grayscale-0 transition-all duration-500"
                  loading="lazy"
                />
              ) : (
                <div
                  class="w-full aspect-video bg-border mb-8 flex items-center justify-center"
                  aria-hidden="true"
                >
                  <span class="text-xs tracking-[0.2em] uppercase text-mid">Visual TBC</span>
                </div>
              )}
              <p class="text-[10px] font-medium tracking-[0.2em] uppercase text-mid mb-2">{item.category} · {item.year}</p>
              <h3 class="text-lg font-serif text-charcoal mb-2">{item.client}</h3>
              <p class="text-sm text-mid leading-relaxed">{item.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <!-- Empty state — shows while portfolio is being built -->
      <div class="border border-border p-16 md:p-24 flex flex-col items-center justify-center text-center gap-6">
        <!-- Placeholder waveform -->
        <div class="flex items-end gap-1 h-10 opacity-20" aria-hidden="true">
          {[40, 70, 90, 55, 80, 45, 95, 60].map((h) => (
            <div class="w-1 bg-charcoal rounded-t-sm" style={`height: ${h}%`} />
          ))}
        </div>
        <p class="text-sm text-mid">{t.work.empty}</p>
      </div>
    )}
  </div>
</section>
