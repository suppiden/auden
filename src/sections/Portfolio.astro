---
import type { Translations } from '../i18n/en';
import { portfolio } from '../data/portfolio';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const hasWork = portfolio.length > 0;
---

<section id="work" class="py-28 md:py-36 px-6 md:px-10 bg-cream border-t border-border" aria-labelledby="work-headline">
  <div class="max-w-8xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 md:mb-24">
      <div>
        <p class="section-eyebrow mb-5" data-reveal>{t.work.eyebrow}</p>
        <h2 id="work-headline" class="section-headline uppercase" data-split-reveal>{t.work.headline}</h2>
      </div>
    </div>

    {hasWork ? (
      <!-- Portfolio grid — renders when items are available -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        {portfolio.map((item) => (
          <article class="group">
            <!-- Video or cover image -->
            {item.videoUrl ? (
              <div class="relative w-full aspect-video mb-6 overflow-hidden rounded-sm border border-border/30">
                <iframe
                  src={item.videoUrl}
                  title={item.client}
                  width="800"
                  height="450"
                  class="absolute inset-0 w-full h-full"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                />
              </div>
            ) : item.cover ? (
              <a
                href={item.caseStudyUrl ?? '#work'}
                class="block focus-visible:outline focus-visible:outline-2 focus-visible:outline-charcoal"
                aria-label={`${item.client} — ${item.category}`}
              >
                <img
                  src={item.cover}
                  alt={item.client}
                  width="800"
                  height="500"
                  class="w-full aspect-video object-cover mb-6 grayscale group-hover:grayscale-0 transition-all duration-500 rounded-sm"
                  loading="lazy"
                />
              </a>
            ) : (
              <div
                class="w-full aspect-video bg-border mb-6 flex items-center justify-center rounded-sm"
                aria-hidden="true"
              >
                <span class="text-xs tracking-[0.2em] uppercase text-mid">Visual TBC</span>
              </div>
            )}
            <p class="text-[10px] font-medium tracking-[0.2em] uppercase text-mid mb-2">{item.category} · {item.year}</p>
            <h3 class="text-lg font-serif text-charcoal mb-1">{item.client}</h3>
            <p class="text-sm text-mid leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    ) : (
      <!-- Empty state — shows while portfolio is being built -->
      <div class="border border-border p-16 md:p-24 flex flex-col items-center justify-center text-center gap-6">
        <p class="text-sm text-mid">{t.work.empty}</p>
      </div>
    )}
  </div>
</section>
