---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="bg-cream overflow-hidden">
  <!-- Statement logo with sound wave emanation -->
  <div class="relative border-t border-border px-6 md:px-10 pt-20 pb-16 flex flex-col items-center justify-center text-center overflow-hidden">
    <!-- Sound ripple rings -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
      <div class="sonar-ring-footer sonar-ring-footer--1"></div>
      <div class="sonar-ring-footer sonar-ring-footer--2"></div>
    </div>

    <a
      href={t.lang === 'es' ? '/es/' : '/'}
      aria-label="Auden home"
      class="relative inline-block mb-6 group"
      style="z-index: 1;"
      data-logo
    >
      <img
        src="/auden_u_palabra_white.png"
        alt="Auden"
        class="hidden dark:block transition-all duration-500 group-hover:opacity-70"
        style="height: clamp(3rem, 8vw, 7rem);"
      />
      <img
        src="/auden_u_palabra_black.png"
        alt="Auden"
        class="block dark:hidden transition-all duration-500 group-hover:opacity-70"
        style="height: clamp(3rem, 8vw, 7rem);"
      />
    </a>

    <!-- Waveform bars below logo -->
    <div class="flex items-end justify-center gap-[3px] h-6 mb-6" aria-hidden="true">
      {[30, 55, 80, 100, 70, 90, 45, 65, 85, 50, 75, 95, 60, 40].map((h, i) => (
        <div
          class="w-[2px] rounded-full wave-bar"
          style={`height: ${h}%; background: rgb(var(--color-fire)); opacity: 0.4; --duration: ${0.7 + (i * 0.08)}s; --delay: ${i * 0.05}s;`}
        />
      ))}
    </div>

    <p class="relative text-xs text-mid tracking-[0.25em] uppercase" style="z-index: 1;">{t.footer.tagline}</p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border px-6 md:px-10 py-5">
    <div class="max-w-8xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-mid">
      <span>{t.footer.rights}</span>
      <a
        href={t.nav.langSwitchHref}
        class="nav-link hover:text-charcoal transition-colors pb-0.5"
      >
        {t.nav.langSwitch}
      </a>
    </div>
  </div>
</footer>
