---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="bg-cream overflow-hidden">
  <!-- Statement logo -->
  <div class="relative border-t border-border px-6 md:px-10 pt-20 pb-16 flex flex-col items-center justify-center text-center">
    <a
      href={t.lang === 'es' ? '/es/' : '/'}
      aria-label="Auden home"
      class="relative inline-block mb-6 group"
      data-logo
    >
      <img
        src="/auden_isotipo_white.png"
        alt="Auden"
        class="hidden dark:block transition-all duration-500 group-hover:opacity-70"
        style="height: clamp(3rem, 8vw, 5rem);"
      />
      <img
        src="/auden_isotipo_black.png"
        alt="Auden"
        class="block dark:hidden transition-all duration-500 group-hover:opacity-70"
        style="height: clamp(3rem, 8vw, 5rem);"
      />
    </a>

    <p class="text-xs text-mid tracking-[0.25em] uppercase">{t.footer.tagline}</p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border px-6 md:px-10 py-5">
    <div class="max-w-8xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-mid">
      <span>{t.footer.rights}</span>
      <div class="flex items-center gap-4">
        <a
          href="mailto:hello@audensonic.com"
          class="nav-link hover:text-charcoal transition-colors pb-0.5"
        >
          hello@audensonic.com
        </a>
        <a
          href={t.nav.langSwitchHref}
          class="nav-link hover:text-charcoal transition-colors pb-0.5"
        >
          {t.nav.langSwitch}
        </a>
      </div>
    </div>
  </div>
</footer>
