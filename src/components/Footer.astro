---
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="border-t border-border px-6 md:px-10 py-10 bg-cream">
  <div class="max-w-8xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <!-- Logo -->
    <a href={t.lang === 'es' ? '/es/' : '/'} aria-label="Auden home" class="text-base font-serif tracking-widest text-charcoal">
      AUDEN
    </a>

    <!-- Tagline -->
    <p class="text-xs text-mid tracking-wide">{t.footer.tagline}</p>

    <!-- Rights & lang -->
    <div class="flex items-center gap-6 text-xs text-mid">
      <span>{t.footer.rights}</span>
      <a href={t.nav.langSwitchHref} class="hover:text-charcoal transition-colors">
        {t.nav.langSwitch}
      </a>
    </div>
  </div>
</footer>
