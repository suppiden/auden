---
import '../styles/global.css';
import type { Translations } from '../i18n/en';

interface Props {
  t: Translations;
  canonicalUrl: string;
  alternateUrl: string;
}

const { t, canonicalUrl, alternateUrl } = Astro.props;
const isEn = t.lang === 'en';
const alternateLang = isEn ? 'es' : 'en';
---

<!doctype html>
<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{t.site.title}</title>
    <meta name="description" content={t.site.description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={t.lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={isEn ? canonicalUrl : alternateUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={t.site.title} />
    <meta property="og:description" content={t.site.description} />
    <meta property="og:image" content={`https://audensonic.com${t.site.ogImage}`} />
    <meta property="og:locale" content={t.lang === 'en' ? 'en_US' : 'es_ES'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.site.title} />
    <meta name="twitter:description" content={t.site.description} />
    <meta name="twitter:image" content={`https://audensonic.com${t.site.ogImage}`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        { '@type': 'Organization', '@id': 'https://audensonic.com/#org', name: 'Auden', url: 'https://audensonic.com', description: 'Sonic branding agency.' },
        { '@type': 'WebSite', '@id': 'https://audensonic.com/#website', url: 'https://audensonic.com', name: 'Auden', publisher: { '@id': 'https://audensonic.com/#org' } },
        { '@type': 'Service', '@id': 'https://audensonic.com/#service', name: 'Sonic Branding', provider: { '@id': 'https://audensonic.com/#org' }, areaServed: 'Worldwide' },
      ],
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preload" href="/auden_isotipo_white.png" as="image" />
    <link rel="preload" href="/auden_logo_white.png" as="image" />

    <script is:inline>
      const theme = localStorage.getItem('theme') ?? 'dark';
      document.documentElement.classList.toggle('dark', theme === 'dark');
      // Pre-set hero logo src for dark mode (before paint)
      if (theme === 'dark') {
        document.addEventListener('DOMContentLoaded', () => {
          const h = document.getElementById('hero-wordmark');
          if (h) h.setAttribute('src', '/auden_logo_white.png');
        });
      }
    </script>
  </head>
  <body>
    <!-- ── Intro Splash ─────────────────────────────────────────────── -->
    <div id="intro-splash" aria-hidden="true">
      <div class="intro-inner">
        <img
          id="intro-isotipo"
          src="/auden_isotipo_white.png"
          alt=""
          class="intro-asset intro-isotipo"
        />
        <img
          id="intro-wordmark"
          src="/auden_logo_white.png"
          alt=""
          class="intro-asset intro-wordmark"
        />
      </div>
    </div>

    <!-- ── Intro audio logo — disabled for now; browser autoplay policies
         prevent sound without user interaction. Uncomment to re-enable. ── -->
    <!--
    <audio id="intro-audio" preload="auto" aria-hidden="true">
      <source src="/audio/auden-logo.mp3" type="audio/mpeg" />
    </audio>
    -->

    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>

    <!-- Fixed nav lives OUTSIDE the scroll container so iOS Safari
         can't drift it (WebKit bug 297779). -->
    <slot name="nav" />

    <!-- ── iOS Safari bulletproof scroll container ─────────────────────
         Body is locked (overflow:hidden). All content scrolls inside
         this wrapper. Fixes iOS 26 WebKit bug 297779 where fixed nav
         drifts when URL bar hides on scroll — URL bar never hides now. -->
    <div id="scroll-container">
      <slot />
    </div>

    <script>
      // ── Custom cursor ─────────────────────────────────────────────
      const dot  = document.querySelector('.cursor-dot')  as HTMLElement | null;
      const ring = document.querySelector('.cursor-ring') as HTMLElement | null;

      if (dot && ring) {
        let mx = window.innerWidth / 2, my = window.innerHeight / 2;
        let rx = mx, ry = my;

        document.addEventListener('mousemove', (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.left = mx + 'px';
          dot.style.top  = my + 'px';
        });

        (function tick() {
          rx += (mx - rx) * 0.1;
          ry += (my - ry) * 0.1;
          ring.style.left = rx + 'px';
          ring.style.top  = ry + 'px';
          requestAnimationFrame(tick);
        })();

        document.querySelectorAll('a, button, [data-tilt]').forEach(el => {
          el.addEventListener('mouseenter', () => document.body.classList.add('is-hovering'));
          el.addEventListener('mouseleave', () => document.body.classList.remove('is-hovering'));
        });
      }

      // ── 3D tilt ───────────────────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-tilt]').forEach(el => {
        el.addEventListener('mousemove', (e) => {
          const r = el.getBoundingClientRect();
          const x = ((e.clientX - r.left) / r.width  - 0.5) * 14;
          const y = ((e.clientY - r.top)  / r.height - 0.5) * -14;
          el.style.transform  = `perspective(900px) rotateX(${y}deg) rotateY(${x}deg) translateZ(6px)`;
          el.style.transition = 'transform 0.06s ease';
        });
        el.addEventListener('mouseleave', () => {
          el.style.transform  = '';
          el.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
        });
      });

      // ── Logo scale on scroll (scroll container, not window) ───────
      const logoImgs  = document.querySelectorAll<HTMLElement>('[data-logo] img');
      const nav       = document.querySelector('[data-nav]') as HTMLElement | null;
      const scroller  = document.getElementById('scroll-container') as HTMLElement | null;

      scroller?.addEventListener('scroll', () => {
        const atTop = scroller.scrollTop < 20;
        logoImgs.forEach(img => { img.style.height = atTop ? '2.25rem' : '1.75rem'; });
        if (nav) {
          nav.classList.toggle('is-scrolled', !atTop);
        }
      }, { passive: true });

      // ── Scroll reveals — observe the scroll container so reveals fire ──
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        });
      }, { root: scroller, threshold: 0.1 });

      document.querySelectorAll(
        '[data-reveal], [data-reveal-stagger], [data-reveal-text], [data-reveal-wipe]'
      ).forEach(el => io.observe(el));

      // ── Masked split-line text reveal ────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-split-reveal]').forEach(el => {
        const text = el.textContent?.trim() ?? '';
        const words = text.split(/\s+/);
        el.innerHTML = '';
        el.setAttribute('aria-label', text);

        words.forEach((word, i) => {
          const mask = document.createElement('span');
          mask.style.cssText = 'display: inline-block; overflow: hidden; vertical-align: top;';

          const inner = document.createElement('span');
          inner.textContent = word;
          inner.style.cssText = `display: inline-block; transform: translateY(110%); transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1); transition-delay: ${i * 0.06}s;`;
          inner.classList.add('split-word');

          mask.appendChild(inner);
          el.appendChild(mask);

          // Add whitespace between words
          if (i < words.length - 1) {
            el.appendChild(document.createTextNode('\u00A0'));
          }
        });
      });

      // Observe split-reveal elements (rooted to scroll container)
      const splitIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.querySelectorAll<HTMLElement>('.split-word').forEach(w => {
              w.style.transform = 'translateY(0)';
            });
            splitIO.unobserve(e.target);
          }
        });
      }, { root: scroller, threshold: 0.15 });

      document.querySelectorAll('[data-split-reveal]').forEach(el => splitIO.observe(el));

      // ── Intro audio logo — DISABLED. Browser autoplay policies block sound
      //    without user interaction. Uncomment this block and the <audio> tag
      //    above to re-enable (plays on every page load, retries on first tap). ──
      /*
      function playIntroAudio() {
        const audio = document.getElementById('intro-audio') as HTMLAudioElement | null;
        if (!audio) return;
        audio.volume = 0.6;

        let unlocked = false;
        const events = ['click', 'touchstart', 'pointerdown', 'keydown', 'scroll'] as const;

        const unlock = () => {
          if (unlocked) return;
          const attempt = audio.play();
          if (attempt !== undefined) {
            attempt.then(() => {
              unlocked = true;
              events.forEach(evt => window.removeEventListener(evt, unlock, true));
            }).catch(() => { });
          }
        };

        unlock();
        events.forEach(evt =>
          window.addEventListener(evt, unlock, { capture: true, passive: true })
        );
      }
      */

      // ── Intro splash orchestration ──────────────────────────────────
      const splash = document.getElementById('intro-splash');
      if (splash) {
        const iso = document.getElementById('intro-isotipo') as HTMLImageElement;
        const word = document.getElementById('intro-wordmark') as HTMLImageElement;
        const heroWord = document.getElementById('hero-wordmark');

        function imgReady(img: HTMLImageElement): Promise<boolean> {
          if (img.complete && img.naturalWidth > 0) return Promise.resolve(true);
          return new Promise(r => {
            img.onload = () => r(true);
            img.onerror = () => r(false);
          });
        }

        function runIntro() {
          // Audio logo disabled — see playIntroAudio() block above
          // playIntroAudio();

          // Phase 1: Isotipo pulse
          requestAnimationFrame(() => iso.classList.add('is-active'));

          // Phase 2: After 1 pulse, swap to wordmark
          setTimeout(() => {
            iso.classList.add('is-exit');
            splash.classList.add('intro-flash');
            setTimeout(() => word.classList.add('is-active'), 250);
          }, 1300);

          // Phase 3: Fly wordmark to hero position + fade background
          setTimeout(() => {
            if (heroWord) {
              const from = word.getBoundingClientRect();
              const to = heroWord.getBoundingClientRect();
              const dx = (to.left + to.width / 2) - (from.left + from.width / 2);
              const dy = (to.top + to.height / 2) - (from.top + from.height / 2);
              const s = to.width / from.width;

              word.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s ease';
              word.style.transform = `translate(${dx}px, ${dy}px) scale(${s})`;
              word.style.filter = 'none';
            }

            splash.style.transition = 'background 0.6s ease';
            splash.style.background = 'transparent';
            splash.style.pointerEvents = 'none';

            setTimeout(() => {
              word.style.transition = 'opacity 0.2s ease';
              word.style.opacity = '0';
              setTimeout(() => {
                splash.remove();
                // Transition hero logo: white → black
                if (heroWord) {
                  setTimeout(() => {
                    const isDark = document.documentElement.classList.contains('dark');
                    // In dark mode use white logo as-is; in light mode apply brightness(0)
                    if (isDark) {
                      (heroWord as HTMLImageElement).src = '/auden_logo_white.png';
                    } else {
                      heroWord.classList.add('hero-logo-ready');
                    }
                    const glow = document.getElementById('hero-logo-glow');
                    if (glow) glow.style.opacity = '1';
                  }, 300);
                }
              }, 250);
            }, 750);
          }, 2300);
        }

        // Wait for images (max 2s), skip intro if they fail
        Promise.race([
          Promise.all([imgReady(iso), imgReady(word)]).then(r => r.every(Boolean)),
          new Promise<false>(r => setTimeout(() => r(false), 2000)),
        ]).then(ok => {
          if (ok) {
            runIntro();
          } else {
            splash.remove();
            // playIntroAudio();
          }
        });
      }
      // else: prefers-reduced-motion skipped the splash — audio disabled
    </script>
  </body>
</html>
